generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Workspace {
  workspace_id Int      @id @default(autoincrement())
  name         String // ชื่อ Workspace เช่น "บริษัท A", "ร้านขายเสื้อผ้า"
  created_at   DateTime @default(now())

  members  WorkspaceMember[]
  channels Channel[] // ช่องทางติดต่อทั้งหมดของ Workspace นี้
  invites  WorkspaceInvite[] // เพิ่มบรรทัดนี้: เก็บคำเชิญที่ถูกส่งจาก Workspace นี้
}

model WorkspaceMember {
  workspace_member_id Int @id @default(autoincrement())

  workspace_id Int
  user_id      Int
  role         Role     @default(EMPLOYEE) // กำหนดสิทธิ์ใน Workspace ได้
  joined_at    DateTime @default(now())

  workspace Workspace @relation(fields: [workspace_id], references: [workspace_id], onDelete: Cascade)
  user      User      @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  @@unique([workspace_id, user_id]) // ป้องกันการแอด User คนเดิมซ้ำเข้า Workspace เดิม
}

// ตารางใหม่: ระบบเก็บคำเชิญเข้าทีม
model WorkspaceInvite {
  invite_id     Int      @id @default(autoincrement())
  workspace_id  Int
  inviter_id    Int // คนที่กดชวน
  invitee_email String // อีเมลคนที่ถูกชวน
  role          String   @default("EMPLOYEE")
  status        String   @default("PENDING") // สถานะ: PENDING, ACCEPTED, DECLINED
  created_at    DateTime @default(now())

  workspace Workspace @relation(fields: [workspace_id], references: [workspace_id], onDelete: Cascade)
  inviter   User      @relation(fields: [inviter_id], references: [user_id], onDelete: Cascade)
}

model User {
  user_id              Int        @id @default(autoincrement())
  username             String
  email                String     @unique
  password             String
  role                 Role       @default(EMPLOYEE)
  profile_image        String?    @db.LongText
  online_status        UserStatus @default(ONLINE)
  current_workspace_id Int?

  emailVerified     DateTime? // บอกว่ายืนยันตอนไหน (ถ้ามีค่าแปลว่ายืนยันแล้ว)
  verificationToken String? // เก็บ OTP 6 หลัก
  tokenExpiry       DateTime? // เก็บเวลาหมดอายุของ OTP

  website      String?
  company      String?
  country      String?
  phone        String?
  company_size String?

  created_at DateTime @default(now())
  is_setup   Boolean  @default(false)

  workspaces   WorkspaceMember[]
  sent_invites WorkspaceInvite[]

  assignments   Assignment[]
  notes         Note[]
  activity_logs ActivityLog[]
  chat_sessions ChatSession[] @relation("AssignedAgent")
}

model Channel {
  channel_id Int @id @default(autoincrement())

  // ผูก Channel เข้ากับ Workspace
  workspace_id Int?
  workspace    Workspace? @relation(fields: [workspace_id], references: [workspace_id], onDelete: Cascade)

  name          String
  platform_name String

  // --- Facebook Credentials ---
  fb_page_id           String?
  fb_page_access_token String? @db.LongText

  // --- LINE Credentials ---
  line_channel_id     String?
  line_channel_secret String?
  line_access_token   String? @db.LongText

  // --- Telegram Credentials ---
  telegram_bot_token String?

  status     ConnectionStatus @default(CONNECTED)
  created_at DateTime         @default(now())
  updated_at DateTime         @updatedAt

  chat_sessions   ChatSession[]
  social_accounts CustomerSocialAccount[]
}

model Customer {
  customer_id Int      @id @default(autoincrement())
  name        String
  image       String?  @db.LongText
  email       String?
  phone       String?
  company     String?
  country     String?
  created_at  DateTime @default(now())
  social_accounts CustomerSocialAccount[]
  chat_sessions   ChatSession[]
  tags            CustomerTag[]
}

model CustomerSocialAccount {
  social_account_id Int @id @default(autoincrement())
  customer_id Int
  channel_id  Int
  account_identifier String
  customer Customer @relation(fields: [customer_id], references: [customer_id])
  channel  Channel  @relation(fields: [channel_id], references: [channel_id])
}

model AiAgent {
  id           Int      @id @default(autoincrement())
  name         String
  emoji        String
  greeting     String   @db.Text
  instructions String   @db.Text
  tone         String
  guardrails   String   @db.Text
  lead_gen     Json? // เก็บสถานะ Enabled และ Prompt ของ Lead Gen
  handover     Json? // เก็บสถานะ Enabled และ Fallback Msg
  is_published Boolean  @default(false)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
}

model ChatSession {
  chat_session_id Int @id @default(autoincrement())
  customer_id Int
  channel_id  Int
  assigned_user_id Int?
  ai_agent_id      Int?
  board_column_id  String?      @default("col-1")
  board_column     BoardColumn? @relation(fields: [board_column_id], references: [column_id])
  status     ChatStatus @default(OPEN)
  start_time DateTime   @default(now())
  end_time   DateTime?

  customer Customer @relation(fields: [customer_id], references: [customer_id])
  channel  Channel  @relation(fields: [channel_id], references: [channel_id]) // 🔥 โยงหา Channel โดยตรง

  assigned_user User? @relation("AssignedAgent", fields: [assigned_user_id], references: [user_id])

  messages    Message[]
  notes       Note[]
  assignments Assignment[]
  tags        ChatTag[]
  logs        ActivityLog[]
}

model Message {
  message_id Int @id @default(autoincrement())

  chat_session_id Int

  sender_type SenderType
  sender_id   Int?

  message_type MessageType
  content      String?     @db.LongText

  external_id    String? @unique
  is_read        Boolean @default(false)
  attachment_url String?

  created_at DateTime  @default(now())
  read_at    DateTime?

  chat_session ChatSession @relation(fields: [chat_session_id], references: [chat_session_id])
}

// ------------------------------------------------------
// UTILITIES (Board, Notes, Assignments, Tags, Logs)
// ------------------------------------------------------
model BoardColumn {
  column_id   String   @id
  title       String
  order_index Int      @default(0)
  created_at  DateTime @default(now())

  chat_sessions ChatSession[]
}

model Note {
  note_id         Int      @id @default(autoincrement())
  chat_session_id Int
  user_id         Int
  title           String?
  content         String   @db.LongText
  created_at      DateTime @default(now())
  is_deleted      Boolean  @default(false)

  chat_session ChatSession @relation(fields: [chat_session_id], references: [chat_session_id])
  user         User        @relation(fields: [user_id], references: [user_id])
}

model Assignment {
  assignment_id Int @id @default(autoincrement())

  chat_session_id Int
  user_id         Int

  topic    String?
  detail   String?          @db.Text
  deadline DateTime?
  status   AssignmentStatus @default(PENDING)

  chat_session ChatSession @relation(fields: [chat_session_id], references: [chat_session_id])
  user         User        @relation(fields: [user_id], references: [user_id])
}

model Tag {
  tag_id      Int     @id @default(autoincrement())
  tag_name    String  @unique
  color       String?
  description String?

  customers CustomerTag[]
  chats     ChatTag[]
}

model CustomerTag {
  customer_tag_id Int @id @default(autoincrement())

  customer_id Int
  tag_id      Int

  customer Customer @relation(fields: [customer_id], references: [customer_id])
  tag      Tag      @relation(fields: [tag_id], references: [tag_id])
}

model ChatTag {
  chat_tag_id Int @id @default(autoincrement())

  chat_session_id Int
  tag_id          Int

  chat ChatSession @relation(fields: [chat_session_id], references: [chat_session_id])
  tag  Tag         @relation(fields: [tag_id], references: [tag_id])
}

model ActivityLog {
  log_id Int @id @default(autoincrement())

  user_id         Int?
  chat_session_id Int?

  action    String
  old_value String?
  new_value String?

  created_at DateTime @default(now())

  user User?        @relation(fields: [user_id], references: [user_id])
  chat ChatSession? @relation(fields: [chat_session_id], references: [chat_session_id])
}

// ------------------------------------------------------
// ENUMS
// ------------------------------------------------------
enum Role {
  USER
  ADMIN
  EMPLOYEE
  MANAGER
  Owner
}

enum UserStatus {
  ONLINE
  OFFLINE
  AWAY
}

enum SenderType {
  CUSTOMER
  AGENT
  BOT
  SYSTEM
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  VIDEO
  AUDIO
}

enum ChatStatus {
  NEW
  OPEN
  PENDING
  CLOSED
  RESOLVED
}

enum AssignmentStatus {
  PENDING
  IN_PROGRESS
  DONE
}

enum ConnectionStatus {
  CONNECTED
  DISCONNECTED
  ERROR
}
